{
  "manifest_version": 3,
  "name": "Ultra Browser",
  "version": "2.0.0",
  "description": "AI Browser Agent com suporte a MCPs e subagentes",
  "permissions": [
    "sidePanel",
    "tabs",
    "activeTab",
    "scripting",
    "debugger",
    "storage",
    "downloads"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "action": {
    "default_title": "Ultra Browser"
  },
  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  }
}
