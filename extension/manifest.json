{
  "manifest_version": 3,
  "name": "Ultra Browser Extension",
  "version": "1.0.0",
  "description": "MCP bridge for Ultra Browser",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "alarms",
    "debugger"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  }
}
